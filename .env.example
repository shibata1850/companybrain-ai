# =========================================================
# CompanyBrain AI — Environment Variables
# Copy this file to .env.local and fill in the values.
# =========================================================

# ---- Supabase ----
# Project URL (e.g. https://abcd1234.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Anon (public) key — used in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — used in API routes ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Bucket name used to store uploaded training videos and generated videos
SUPABASE_STORAGE_BUCKET=companybrain

# ---- Google Gemini ----
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Models (override only if you know what you're doing)
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ---- HeyGen ----
# Get one at https://app.heygen.com/settings?nav=API
HEYGEN_API_KEY=
