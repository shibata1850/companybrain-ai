# =========================================================
# CompanyBrain AI — Environment Variables
# Copy this file to .env.local and fill in the values.
# =========================================================

# ---- Supabase ----
# Project URL (e.g. https://abcd1234.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Anon (public) key — used in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — used in API routes ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Bucket name used to store uploaded training videos and generated videos
SUPABASE_STORAGE_BUCKET=companybrain

# ---- Google Gemini ----
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model used to answer questions as the persona. Pro is smarter and gives
# more in-character responses; switch to flash for cheaper/faster.
# Candidates: gemini-2.5-pro / gemini-2.5-flash / gemini-pro-latest /
# gemini-flash-latest. Falls back automatically if the chosen one is not
# available on this API key.
GEMINI_ANSWER_MODEL=gemini-2.5-pro
# Model used to transcribe uploaded training videos. Flash is fine here.
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ---- HeyGen ----
# Get one at https://app.heygen.com/settings?nav=API
HEYGEN_API_KEY=
# Output video dimensions. Defaults to 1080x1920 (portrait full HD) for
# max quality. HeyGen bills per second, not by resolution.
# Standard 9:16 sizes: 360x640, 480x854, 720x1280, 1080x1920.
# Landscape: 640x360, 854x480, 1280x720, 1920x1080.
# HEYGEN_VIDEO_WIDTH=1080
# HEYGEN_VIDEO_HEIGHT=1920

# Lip-sync / avatar engine.
#   premium  = try Avatar IV (V4) first, fall back to classic on failure.
#              Best lip-sync fidelity, costs ~2-3x per second.
#   standard = classic talking_photo only. Cheaper.
# HEYGEN_AVATAR_QUALITY=premium
