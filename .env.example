# =========================================================
# CompanyBrain AI — Environment Variables
# Copy this file to .env.local and fill in the values.
# =========================================================

# ---- Supabase ----
# Project URL (e.g. https://abcd1234.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Anon (public) key — used in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — used in API routes ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Bucket name used to store uploaded training videos and generated videos
SUPABASE_STORAGE_BUCKET=companybrain

# ---- Google Gemini ----
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model used to answer questions as the persona. Pro is smarter and gives
# more in-character responses; switch to flash for cheaper/faster.
# Candidates: gemini-2.5-pro / gemini-2.5-flash / gemini-pro-latest /
# gemini-flash-latest. Falls back automatically if the chosen one is not
# available on this API key.
GEMINI_ANSWER_MODEL=gemini-2.5-pro
# Model used to transcribe uploaded training videos. Flash is fine here.
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ---- Gemini Live API (real-time voice conversation) ----
# Uses the same GEMINI_API_KEY above. Make sure the key belongs to a
# project that has Live API access enabled (paid tier).
# Model used for the live audio dialog.
# Stable choice (recommended): gemini-2.0-flash-live-001
# Preview half-cascade:        gemini-live-2.5-flash-preview
# Preview native-audio-dialog: gemini-2.5-flash-preview-native-audio-dialog
#   (the preview models need preview access on your project)
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
# Voice the agent speaks with. Multi-lingual incl. Japanese.
# Options: Aoede, Charon, Fenrir, Kore, Leda, Orus, Puck, Zephyr.
GEMINI_LIVE_VOICE=Kore

# ---- HeyGen (legacy, not used in Gemini Live mode) ----
# HEYGEN_API_KEY=
# HEYGEN_INTERACTIVE_AVATAR_ID=Wayne_20240711
# HEYGEN_INTERACTIVE_LANGUAGE=ja

# ---- D-ID (legacy, not used in Live Avatar mode) ----
# DID_API_KEY=
# DID_VOICE_ID=ja-JP-NanamiNeural
# Output video dimensions. Defaults to 1080x1920 (portrait full HD) for
# max quality. HeyGen bills per second, not by resolution.
# Standard 9:16 sizes: 360x640, 480x854, 720x1280, 1080x1920.
# Landscape: 640x360, 854x480, 1280x720, 1920x1080.
# HEYGEN_VIDEO_WIDTH=1080
# HEYGEN_VIDEO_HEIGHT=1920

# Lip-sync / avatar engine.
#   premium  = try Avatar IV (V4) first, fall back to classic on failure.
#              Best lip-sync fidelity, costs ~2-3x per second.
#   standard = classic talking_photo only. Cheaper.
# HEYGEN_AVATAR_QUALITY=premium

# Background replacement for the generated video. Defaults to a warm
# neutral wall colour that reads as a calm office.
#   HEYGEN_BACKGROUND_TYPE: color | image | video | none
#   HEYGEN_BACKGROUND_VALUE: hex (#rrggbb) for color, public URL for image/video
# Examples:
#   HEYGEN_BACKGROUND_TYPE=color
#   HEYGEN_BACKGROUND_VALUE=#e8e4dc        # default
#   HEYGEN_BACKGROUND_VALUE=#f5f3ee        # warmer beige
#   HEYGEN_BACKGROUND_VALUE=#1f2937        # dark slate (formal)
# Or use an office image:
#   HEYGEN_BACKGROUND_TYPE=image
#   HEYGEN_BACKGROUND_VALUE=https://example.com/office.jpg
# HEYGEN_BACKGROUND_TYPE=color
# HEYGEN_BACKGROUND_VALUE=#e8e4dc
