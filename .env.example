# =========================================================
# CompanyBrain AI — 環境変数テンプレート (Local-only stack)
# このファイルをコピーして .env.local を作る
# =========================================================

# ---- Frontend (Vite) ----
VITE_API_BASE_URL=/api
VITE_API_PROXY=http://localhost:3001

# ---- Backend (Hono) ----
SERVER_PORT=3001

# SQLite DB ファイルの保存先 (省略時: ./data/companybrain.db)
# DB_PATH=./data/companybrain.db

# アップロードファイルの保存先 (省略時: ./uploads)
# UPLOAD_DIR=./uploads

# JWT 署名キー (必須: 32文字以上のランダム文字列。未設定だと再起動でセッション失効)
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=please_replace_with_a_long_random_string_at_least_32_chars

# Gemini API キー (必須: AI チャット・方針抽出に使用)
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy....
GEMINI_MODEL=gemini-2.0-flash
