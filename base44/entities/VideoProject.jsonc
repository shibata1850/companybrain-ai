{
  "name": "VideoProject",
  "type": "object",
  "properties": {
    "clientCompanyId": {
      "type": "string",
      "description": "\u4f01\u696dID"
    },
    "title": {
      "type": "string",
      "description": "\u30bf\u30a4\u30c8\u30eb"
    },
    "purpose": {
      "type": "string",
      "enum": [
        "company_intro",
        "service_intro",
        "sales",
        "training",
        "recruiting",
        "faq",
        "other"
      ],
      "description": "\u7528\u9014"
    },
    "script": {
      "type": "string",
      "description": "\u53f0\u672c"
    },
    "scriptStatus": {
      "type": "string",
      "enum": [
        "draft",
        "approved",
        "rejected"
      ],
      "default": "draft",
      "description": "\u53f0\u672c\u30b9\u30c6\u30fc\u30bf\u30b9"
    },
    "voiceMode": {
      "type": "string",
      "enum": [
        "openai_tts",
        "heygen_voice",
        "uploaded_audio"
      ],
      "description": "\u97f3\u58f0\u30e2\u30fc\u30c9"
    },
    "ttsVoice": {
      "type": "string",
      "description": "TTS\u30dc\u30a4\u30b9\u540d"
    },
    "videoFileUrl": {
      "type": "string",
      "description": "\u52d5\u753b\u30d5\u30a1\u30a4\u30ebURL\uff08\u516c\u958b\uff09"
    },
    "videoFileUri": {
      "type": "string",
      "description": "\u52d5\u753b\u30d5\u30a1\u30a4\u30ebURI\uff08\u30d7\u30e9\u30a4\u30d9\u30fc\u30c8\uff09"
    },
    "audioFileUrl": {
      "type": "string",
      "description": "\u97f3\u58f0\u30d5\u30a1\u30a4\u30ebURL\uff08\u516c\u958b\uff09"
    },
    "audioFileUri": {
      "type": "string",
      "description": "\u97f3\u58f0\u30d5\u30a1\u30a4\u30ebURI\uff08\u30d7\u30e9\u30a4\u30d9\u30fc\u30c8\uff09"
    },
    "heygenJobId": {
      "type": "string",
      "description": "HeyGen \u30b8\u30e7\u30d6ID"
    },
    "outputVideoUrl": {
      "type": "string",
      "description": "\u51fa\u529b\u52d5\u753bURL"
    },
    "lipsyncMode": {
      "type": "string",
      "enum": [
        "speed",
        "precision"
      ],
      "description": "\u30ea\u30c3\u30d7\u30b7\u30f3\u30af\u30e2\u30fc\u30c9"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "script_ready",
        "audio_ready",
        "processing",
        "completed",
        "failed"
      ],
      "default": "draft",
      "description": "\u30b9\u30c6\u30fc\u30bf\u30b9"
    },
    "durationSeconds": {
      "type": "number",
      "description": "\u52d5\u753b\u5c3a\uff08\u79d2\uff09"
    },
    "errorMessage": {
      "type": "string",
      "description": "\u30a8\u30e9\u30fc\u30e1\u30c3\u30bb\u30fc\u30b8"
    }
  },
  "required": [
    "clientCompanyId",
    "title"
  ]
}