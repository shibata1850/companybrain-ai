{
  "name": "AvatarConversationSession",
  "type": "object",
  "properties": {
    "clientCompanyId": {
      "type": "string",
      "description": "\u4f01\u696dID"
    },
    "avatarProfileId": {
      "type": "string",
      "description": "ExecutiveAvatarProfile ID"
    },
    "userId": {
      "type": "string",
      "description": "\u30e6\u30fc\u30b6\u30fcID"
    },
    "sessionId": {
      "type": "string",
      "description": "\u5916\u90e8API (LiveAvatar/HeyGen) \u306e\u30bb\u30c3\u30b7\u30e7\u30f3ID"
    },
    "sessionToken": {
      "type": "string",
      "description": "\u30bb\u30c3\u30b7\u30e7\u30f3\u8a8d\u8a3c\u30c8\u30fc\u30af\u30f3"
    },
    "roomUrl": {
      "type": "string",
      "description": "\u30eb\u30fc\u30e0URL"
    },
    "embedUrl": {
      "type": "string",
      "description": "\u57cb\u3081\u8fbc\u307fURL"
    },
    "purpose": {
      "type": "string",
      "enum": [
        "demo",
        "training",
        "roleplay",
        "work_review",
        "consultation"
      ],
      "description": "\u4f1a\u8a71\u76ee\u7684"
    },
    "scenario": {
      "type": "string",
      "description": "\u30b7\u30ca\u30ea\u30aa\uff08\u7814\u4fee\u306e\u5834\u5408\uff09"
    },
    "mode": {
      "type": "string",
      "enum": [
        "FULL",
        "TEXT_FALLBACK"
      ],
      "default": "FULL",
      "description": "\u5b9f\u884c\u30e2\u30fc\u30c9"
    },
    "provider": {
      "type": "string",
      "enum": [
        "liveavatar",
        "heygen",
        "gemini_text"
      ],
      "description": "\u5229\u7528\u30d7\u30ed\u30d0\u30a4\u30c0"
    },
    "transcript": {
      "type": "string",
      "description": "\u4f1a\u8a71\u30ed\u30b0\u30fb\u6587\u5b57\u8d77\u3053\u3057"
    },
    "summary": {
      "type": "string",
      "description": "\u30bb\u30c3\u30b7\u30e7\u30f3\u8981\u7d04"
    },
    "evaluationScore": {
      "type": "number",
      "description": "\u8a55\u4fa1\u30b9\u30b3\u30a2\uff080-100\uff09"
    },
    "advice": {
      "type": "string",
      "description": "\u30a2\u30c9\u30d0\u30a4\u30b9\u30fb\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af"
    },
    "actionItems": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u30a2\u30af\u30b7\u30e7\u30f3\u30a2\u30a4\u30c6\u30e0"
    },
    "needHumanReview": {
      "type": "boolean",
      "default": false,
      "description": "\u4eba\u9593\u306b\u3088\u308b\u78ba\u8a8d\u304c\u5fc5\u8981\u304b"
    },
    "durationSeconds": {
      "type": "number",
      "default": 0,
      "description": "\u30bb\u30c3\u30b7\u30e7\u30f3\u6642\u9593\uff08\u79d2\uff09"
    },
    "endedAt": {
      "type": "string",
      "format": "date-time",
      "description": "\u7d42\u4e86\u65e5\u6642"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "failed"
      ],
      "default": "active",
      "description": "\u30b9\u30c6\u30fc\u30bf\u30b9"
    }
  },
  "required": [
    "clientCompanyId",
    "avatarProfileId",
    "userId",
    "purpose"
  ]
}