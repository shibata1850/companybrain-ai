      "description": "\u30bf\u30fc\u30b2\u30c3\u30c8\u9867\u5ba2"
    },
    "tone": {
      "type": "string",
      "enum": [
        "formal",
        "friendly",
        "professional",
        "casual"
      ],
      "default": "professional",
      "description": "AI\u306e\u56de\u7b54\u30c8\u30fc\u30f3"
