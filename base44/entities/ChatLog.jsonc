{
  "name": "ChatLog",
  "type": "object",
  "properties": {
    "clientCompanyId": {
      "type": "string",
      "description": "\u4f01\u696d\u8b58\u5225ID"
    },
    "mode": {
      "type": "string",
      "enum": [
        "external",
        "internal",
        "executive"
      ],
      "description": "\u30c1\u30e3\u30c3\u30c8\u30e2\u30fc\u30c9"
    },
    "question": {
      "type": "string",
      "description": "\u8cea\u554f"
    },
    "answer": {
      "type": "string",
      "description": "\u56de\u7b54"
    },
    "status": {
      "type": "string",
      "enum": [
        "auto",
        "approved",
        "revised",
        "flagged"
      ],
      "default": "auto",
      "description": "\u627f\u8a8d\u72b6\u614b"
    },
    "revisedAnswer": {
      "type": "string",
      "description": "\u4fee\u6b63\u5f8c\u306e\u56de\u7b54"
    },
    "feedback": {
      "type": "string",
      "enum": [
        "good",
        "bad",
        "none"
      ],
      "default": "none",
      "description": "\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af"
    },
    "sessionId": {
      "type": "string",
      "description": "\u30bb\u30c3\u30b7\u30e7\u30f3ID"
    }
  },
  "required": [
    "question",
    "answer",
    "clientCompanyId"
  ]
}